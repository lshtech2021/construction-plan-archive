# PostgreSQL
POSTGRES_USER=cpa
POSTGRES_PASSWORD=cpa_secret
POSTGRES_DB=construction_archive
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://cpa:cpa_secret@postgres:5432/construction_archive

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Backend
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ENVIRONMENT=development

# PDF Processing
PDF_RENDER_DPI=300
THUMBNAIL_DPI=72
