# PostgreSQL
POSTGRES_USER=cpa
POSTGRES_PASSWORD=cpa_secret
POSTGRES_DB=construction_archive
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://cpa:cpa_secret@postgres:5432/construction_archive

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Backend
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ENVIRONMENT=development

# PDF Processing
PDF_RENDER_DPI=300
THUMBNAIL_DPI=72

# VLM (Vision Language Model) settings
VLM_ENABLED=false
VLM_PROVIDER=openai
VLM_MODEL=gpt-4o
VLM_API_KEY=
VLM_API_BASE=
VLM_MAX_RETRIES=3
VLM_TIMEOUT_SECONDS=60.0

# OCR settings
OCR_ENABLED=true
OCR_DENOISE=true

# Extraction pipeline settings
EXTRACTION_ENABLED=true
TABLE_EXTRACTION_ENABLED=true
EXTRACTION_MAX_WORKERS=4

# Embedding settings
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_API_KEY=
EMBEDDING_DIMENSION=384
IMAGE_EMBEDDING_MODEL=clip-ViT-B-32
IMAGE_EMBEDDING_DIMENSION=512

# Search settings
QDRANT_TEXT_COLLECTION=sheet_text_embeddings
QDRANT_IMAGE_COLLECTION=sheet_image_embeddings
SEARCH_DEFAULT_LIMIT=20
SEARCH_MAX_LIMIT=100
SEARCH_SEMANTIC_WEIGHT=0.7
SEARCH_KEYWORD_WEIGHT=0.3
SEARCH_MIN_SCORE=0.1
SEARCH_ENABLE_RERANKING=true

# Frontend
FRONTEND_PORT=3000
